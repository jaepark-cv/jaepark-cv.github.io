@article{TANG2025104278,
title = {Mass customization and consumer behaviors: Exploring the roles of perceived value, perceived cost, and time pressure},
journal = {International Journal of Hospitality Management},
volume = {130},
pages = {104278},
year = {2025},
issn = {0278-4319},
doi = {https://doi.org/10.1016/j.ijhm.2025.104278},
url = {https://www.sciencedirect.com/science/article/pii/S0278431925002014},
author = {Chun-Hung Hugo Tang and Alei (Aileen) Fan and Jae Eun Park},
keywords = {Customization, Time pressure, Perceived value, Perceived cost},
abstract = {This study explores the effects of mass customization on consumer behaviors, focusing on the roles of perceived value and perceived cost under different sources of time pressure in a fast-casual restaurant setting. Results show that mass customization affects consumer behaviors through perceived value, not perceived cost. Furthermore, customer-induced time pressure is found to interact with mass customization on perceived cost. The findings suggest that social context plays a critical role in the success of mass customization.}
}

